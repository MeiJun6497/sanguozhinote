{% if settings.dgHomeLink === true %}
  <nav class="navbar">
    <div class="navbar-inner" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
      <!-- 左側：網站名稱 -->
      <a href="/" style="text-decoration: none;">
        <h1 style="margin: 15px !important;">{{meta.siteName}}</h1>
      </a>

      <!-- 右側：按鈕群（search + ToC） -->
      <div class="navbar-buttons" style="display: flex; align-items: center; gap: 10px;">
        {% if settings.dgEnableSearch === true %}
          {% include "components/searchButton.njk" %}
        {% endif %}

        <!-- ToC 目錄按鈕 -->
        <button id="toc-toggle" class="toc-toggle-button">目錄</button>
      </div>
    </div>


<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggleBtn = document.getElementById('toc-toggle');
    const tocPanel = document.getElementById('toc-panel');

    if (toggleBtn && tocPanel) {
      toggleBtn.addEventListener('click', function () {
        tocPanel.classList.toggle('toc-visible');
      });
    }
  });
</script>



<div id="toc-panel" class="toc-panel">
  <!-- 你可以用 JavaScript 動態產生目錄，或手動加上連結 -->
  <a href="#section1">第一節</a>
  <a href="#section2">第二節</a>
  <a href="#section3">第三節</a>
</div>


  </nav>
{% else %}
  <div class="empty-navbar">
    {% if settings.dgEnableSearch === true %}
      {% include "components/searchButton.njk" %}
    {% endif %}
  </div>
{% endif %}

